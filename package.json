	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"serv": "npm run dev -- --open",
		"prod": "npm run clean && VITE_BASE_PATH='/axio_calcul' vite build",
